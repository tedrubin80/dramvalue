# =============================================================================
# WTracker Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=WTracker
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=wtracker
POSTGRES_USER=wtracker
POSTGRES_PASSWORD=change-this-password

# Constructed database URL (used by SQLAlchemy)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Email Configuration (for verification)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@wtracker.example.com
SMTP_FROM_NAME=WTracker

# -----------------------------------------------------------------------------
# Scraping Configuration
# -----------------------------------------------------------------------------
SCRAPER_USER_AGENT=WTracker/1.0 (Educational Project)
SCRAPER_RATE_LIMIT_REQUESTS=10
SCRAPER_RATE_LIMIT_PERIOD=60
SCRAPER_RESPECT_ROBOTS_TXT=true
SCRAPER_CACHE_ENABLED=true
SCRAPER_CACHE_TTL_HOURS=24

# -----------------------------------------------------------------------------
# Admin Configuration
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
# Initial admin is created on first run if not exists

# -----------------------------------------------------------------------------
# Trust & Fraud Detection Thresholds
# -----------------------------------------------------------------------------
TRUST_BASE_SCORE=50
TRUST_VERIFIED_BONUS=25
TRUST_SUBMISSION_INCREMENT=1
FRAUD_STDDEV_THRESHOLD=2.0
FRAUD_NEW_ACCOUNT_SUBMISSION_LIMIT=5
FRAUD_BURST_WINDOW_MINUTES=10
FRAUD_BURST_LIMIT=3
FRAUD_SINGLE_USER_INFLUENCE_CAP=0.25

# -----------------------------------------------------------------------------
# Forecasting Configuration
# -----------------------------------------------------------------------------
FORECAST_MIN_DATAPOINTS=10
FORECAST_CONFIDENCE_THRESHOLD=0.6
FORECAST_RECALCULATE_ON_NEW_DATA=true

# -----------------------------------------------------------------------------
# Redis (optional, for future caching/queues)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
PERPLEXITY_API_KEY=your-perplexity-api-key

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# LOG_LEVEL=INFO
